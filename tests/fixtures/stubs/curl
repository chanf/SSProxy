#!/bin/sh
# Test stub for the controller/file `curl` (called via helper.sh's mihomo_curl
# and by update_geox/download_core). Honors `-o <path>` by writing canned data
# to that file; otherwise echoes $CURL_RESPONSE to stdout (for callers that
# grep the body, e.g. resolve_proxy_name).
out=""
while [ $# -gt 0 ]; do
	case "$1" in
		-o) shift; out="$1" ;;
	esac
	shift
done
if [ -n "$out" ]; then
	printf '%s\n' "${CURL_RESPONSE:-fake-data}" > "$out"
else
	[ -n "$CURL_RESPONSE" ] && printf '%s\n' "$CURL_RESPONSE"
fi
exit 0
